{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/__/auth/(.*)", "destination": "https://unique-jewelry-studio.firebaseapp.com/__/auth/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
